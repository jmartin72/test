---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Studio Mercury | Home">
  <section class="space-y-6">
    <p class="text-sm font-semibold uppercase tracking-wide text-indigo-600">Small business web studio</p>
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Beautiful websites that grow local businesses.</h1>
    <p class="max-w-2xl text-lg text-slate-600">We combine thoughtful web design, practical SEO, and AI enhancements to help local businesses attract more customers and streamline their operations.</p>
  </section>
</BaseLayout>
