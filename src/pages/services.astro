---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Services | Studio Mercury">
  <h1 class="text-3xl font-bold">Services</h1>
  <div class="mt-8 grid gap-6 md:grid-cols-3">
    <article id="web-design" class="rounded-lg border border-slate-200 p-5">
      <h2 class="text-xl font-semibold">Web Design</h2>
      <p class="mt-2 text-slate-600">Custom websites designed to build trust and convert visitors into leads.</p>
    </article>
    <article id="seo" class="rounded-lg border border-slate-200 p-5">
      <h2 class="text-xl font-semibold">SEO</h2>
      <p class="mt-2 text-slate-600">Technical and local SEO strategies to improve visibility and generate consistent traffic.</p>
    </article>
    <article id="ai-enhancements" class="rounded-lg border border-slate-200 p-5">
      <h2 class="text-xl font-semibold">AI Enhancements</h2>
      <p class="mt-2 text-slate-600">AI-assisted chat, automation, and workflows that save time for your team and clients.</p>
    </article>
  </div>
</BaseLayout>
